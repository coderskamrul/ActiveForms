{
  "name": "activeforms",
  "version": "1.0.0",
  "description": "ActiveForms – Drag & Drop Form Builder for WordPress (React admin)",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "start": "webpack --watch --mode development",
    "dev": "webpack --mode development",
    "build": "webpack --mode production",
    "makepot": "wp i18n make-pot . languages/activeforms.pot --domain=activeforms --slug=activeforms --exclude=node_modules,src,vendor,build,scripts,plugin-requirements",
    "zip": "npm run build && node scripts/make-zip.mjs",
    "release": "npm run build && npm run makepot && node scripts/make-zip.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "archiver": "^7.0.1",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.11.0",
    "mini-css-extract-plugin": "^2.9.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.0",
    "webpack": "^5.92.0",
    "webpack-cli": "^5.1.4"
  }
}
